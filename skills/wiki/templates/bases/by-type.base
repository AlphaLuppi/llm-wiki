filters:
  and:
    - file.inFolder("wiki")
    - file.ext == "md"
    - 'type != "moc"'
    - 'type != "index"'
    - 'type != "log"'
    - 'type != "schema"'
properties:
  title:
    displayName: "Titre"
  type:
    displayName: "Type"
  tags:
    displayName: "Tags"
  ingested:
    displayName: "Lu"
  ingested_date:
    displayName: "Lu le"
  source_path:
    displayName: "Source"
  file.mtime:
    displayName: "Modifié"
views:
  - type: table
    name: "Sources lues"
    filters:
      and:
        - 'type == "source"'
        - 'ingested == true'
    order:
      - title
      - ingested_date
      - source_path
      - tags
    sort:
      - property: ingested_date
        direction: desc
  - type: table
    name: "Sources à lire (stubs)"
    filters:
      and:
        - 'type == "source"'
        - 'ingested != true'
    order:
      - title
      - source_path
      - tags
      - file.mtime
    sort:
      - property: file.mtime
        direction: desc
  - type: table
    name: "Entities"
    filters:
      and:
        - 'type == "entity"'
    order:
      - title
      - tags
      - file.mtime
    sort:
      - property: title
        direction: asc
  - type: table
    name: "Concepts"
    filters:
      and:
        - 'type == "concept"'
    order:
      - title
      - tags
      - file.mtime
    sort:
      - property: title
        direction: asc
  - type: table
    name: "Comparisons"
    filters:
      and:
        - 'type == "comparison"'
    order:
      - title
      - tags
      - file.mtime
    sort:
      - property: file.mtime
        direction: desc
  - type: table
    name: "Syntheses"
    filters:
      and:
        - 'type == "synthesis"'
    order:
      - title
      - tags
      - file.mtime
    sort:
      - property: file.mtime
        direction: desc
